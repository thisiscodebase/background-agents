{
  "name": "@open-inspect/vercel-infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build --prefix ../shared",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --platform=node --target=node22 --external:node:* --external:@vercel/sandbox",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@open-inspect/shared": "file:../shared",
    "@vercel/sandbox": "beta",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0"
  }
}
