{
  "name": "open-inspect",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL) process.exit(0); const { spawnSync } = require('child_process'); const r = spawnSync('husky', { stdio: 'inherit', shell: true }); process.exit(r.status ?? 1);\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "wrangler": "^4.79.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "undici": "^7.24.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yaml,yml,css}": [
      "prettier --write"
    ],
    "packages/modal-infra/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  }
}
